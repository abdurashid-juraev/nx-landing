{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@org/feature-dashboard": ["libs/admin/feature-dashboard/src/index.ts"],
      "@org/ui-components": ["libs/admin/ui-components/src/index.ts"],
      "@org/data-access-auth": ["auth-data/src/index.ts"],
      "@org/feature-home": ["libs/landing/feature-home/src/index.ts"],
      "@org/ui-hero": ["libs/landing/ui-hero/src/index.ts"],
      "@org/feature-courses": ["libs/student/feature-courses/src/index.ts"],
      "@org/util-formatting": ["libs/shared/util-formatting/src/index.ts"],
      "@org/ui-theme": ["libs/shared/ui-theme/src/index.ts"],
      "@org/env": ["libs/shared/env/src/index.ts"],
      "@org/shared-models": ["libs/shared/models/src/index.ts"],
      "@org/notifications": ["libs/shared/notifications/src/index.ts"],
      "@org/i18n": ["libs/shared/i18n/src/index.ts"],
      "@org/data-access": ["libs/shared/data-access/src/index.ts"],
      "@org/auth": ["libs/shared/auth/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
